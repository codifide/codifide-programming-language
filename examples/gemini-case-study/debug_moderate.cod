module debug_moderate

def classify_content
  intent "classify a message based on keywords"
  sig    (message: String) -> Label
  effects {}
  cand
    intent "unsafe keyword match"
    when   or(contains(message, "spam"), contains(message, "hate"), contains(message, "violence"))
    belief("unsafe", 0.90)
  cand
    intent "safe keyword match"
    when   or(contains(message, "approved"), contains(message, "verified"))
    belief("safe", 0.90)
  cand
    intent "fallback for no keyword match"
    belief("uncertain", 0.75)

def moderate
  intent "refuse classification when confidence is too low"
  sig    (message: String) -> Label
  effects {}
  cand
    result <- classify_content(message)
    believe result
      ge(conf(result), 0.70) => result
      else                   => bottom

def main_spam
  intent "test moderate with spam"
  sig    () -> Label
  effects {}
  cand
    moderate("this message contains spam")

def main_hello
  intent "test moderate with hello world"
  sig    () -> Label
  effects {}
  cand
    moderate("hello world")
