module escalation_router

# Gemini 2.5 Pro case study — Program 3
# Gemini's first attempt used believe for routing on string values —
# anticipated BottomPropagationError. Self-corrected to use
# if/then/else with is_bottom() check.
# Final version uses nested if/then/else in a single cand body.

def classify_content
  intent "classify a message based on keywords"
  sig    (message: String) -> Label
  effects {}
  cand
    intent "unsafe keyword match"
    when   or(contains(message, "spam"), contains(message, "hate"), contains(message, "violence"))
    belief("unsafe", 0.90)
  cand
    intent "safe keyword match"
    when   or(contains(message, "approved"), contains(message, "verified"))
    belief("safe", 0.90)
  cand
    intent "fallback for no keyword match"
    belief("uncertain", 0.75)

def moderate
  intent "refuse classification when confidence is too low"
  sig    (message: String) -> Label
  effects {}
  cand
    result <- classify_content(message)
    believe result
      ge(conf(result), 0.70) => result
      else                   => bottom

def route_message
  intent "route a message based on its moderation status"
  sig    (message: String) -> String
  effects {}
  cand
    moderation_result <- moderate(message)
    if is_bottom(moderation_result) then
      bottom
    else
      if eq(moderation_result, "unsafe") then "blocked"
      else if eq(moderation_result, "safe") then "approved"
      else "escalate-to-human"

def main
  intent "test the escalation router with multiple cases"
  sig    () -> String
  effects {}
  cand
    route_message("this is a verified message")
